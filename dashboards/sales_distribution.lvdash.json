{
  "datasets": [
    {
      "name": "ds_revenue_kpi",
      "displayName": "Revenue KPI (90 days)",
      "queryLines": [
        "SELECT sum(net_revenue) AS net_revenue, sum(units_sold) AS units_sold, sum(orders) AS orders\n",
        "FROM lakeforge_prod.gold.agg_daily_revenue\n",
        "WHERE order_date >= date_add(current_date(), -90)\n"
      ]
    },
    {
      "name": "ds_sla_kpi",
      "displayName": "On-time rate KPI (30 days)",
      "queryLines": [
        "SELECT sum(on_time) / sum(deliveries) AS on_time_rate\n",
        "FROM lakeforge_prod.gold.agg_delivery_sla\n",
        "WHERE planned_date >= date_add(current_date(), -30)\n"
      ]
    },
    {
      "name": "ds_revenue_trend",
      "displayName": "Daily revenue by brand",
      "queryLines": [
        "SELECT order_date, brand, sum(net_revenue) AS net_revenue\n",
        "FROM lakeforge_prod.gold.agg_daily_revenue\n",
        "WHERE order_date >= date_add(current_date(), -90)\n",
        "GROUP BY order_date, brand ORDER BY order_date\n"
      ]
    },
    {
      "name": "ds_revenue_region",
      "displayName": "Revenue by region (90 days)",
      "queryLines": [
        "SELECT region, sum(net_revenue) AS net_revenue, sum(units_sold) AS units_sold\n",
        "FROM lakeforge_prod.gold.agg_daily_revenue\n",
        "WHERE order_date >= date_add(current_date(), -90)\n",
        "GROUP BY region ORDER BY net_revenue DESC\n"
      ]
    },
    {
      "name": "ds_top_distributors",
      "displayName": "Top distributors by cases shipped",
      "queryLines": [
        "SELECT distributor, sum(cases_shipped) AS cases_shipped, sum(shipments) AS shipments\n",
        "FROM lakeforge_prod.gold.agg_distributor_shipments\n",
        "GROUP BY distributor ORDER BY cases_shipped DESC LIMIT 10\n"
      ]
    },
    {
      "name": "ds_sla_trend",
      "displayName": "Delivery SLA by carrier",
      "queryLines": [
        "SELECT planned_date, carrier, sum(on_time) / sum(deliveries) AS on_time_rate\n",
        "FROM lakeforge_prod.gold.agg_delivery_sla\n",
        "WHERE planned_date >= date_add(current_date(), -90)\n",
        "GROUP BY planned_date, carrier ORDER BY planned_date\n"
      ]
    },
    {
      "name": "ds_top_customers",
      "displayName": "Top customers by net revenue",
      "queryLines": [
        "SELECT c.customer_name, c.region, sum(f.net_amount) AS net_revenue,\n",
        "       count(DISTINCT f.order_id) AS orders\n",
        "FROM lakeforge_prod.gold.fact_sales f\n",
        "JOIN lakeforge_prod.gold.dim_customer c USING (customer_sk)\n",
        "WHERE f.status <> 'cancelled'\n",
        "GROUP BY c.customer_name, c.region ORDER BY net_revenue DESC LIMIT 10\n"
      ]
    }
  ],
  "pages": [
    {
      "name": "page_sales",
      "displayName": "Sales & Distribution",
      "layout": [
        {
          "widget": {
            "name": "kpi_revenue",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_revenue_kpi",
                  "fields": [{"name": "net_revenue", "expression": "`net_revenue`"}],
                  "disaggregated": true
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "net_revenue",
                  "format": {"type": "number-currency", "currencyCode": "PLN", "abbreviation": "compact", "decimalPlaces": {"type": "max", "places": 1}},
                  "displayName": "Net revenue (90d)"
                }
              },
              "frame": {"showTitle": true, "title": "Net revenue — last 90 days"}
            }
          },
          "position": {"x": 0, "y": 0, "width": 2, "height": 5}
        },
        {
          "widget": {
            "name": "kpi_units",
